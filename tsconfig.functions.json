{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.functions.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "types": ["@cloudflare/workers-types", "vitest/globals"],
    "skipLibCheck": true,

    /* Path aliases — for type-checking only; the Pages esbuild bundler ignores these,
       which is why functions/*.ts import from src/ via relative paths. Needed here so the
       included spec chain (e.g. src/spec/seed.ts's `@/lib/models`) resolves under tsc. */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Type-checking strictness */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["functions", "src/spec", "src/io/persist.ts"]
}
